# 数据库配置
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=user_manager
MYSQL_PORT=3306

# Redis配置
REDIS_PORT=6379

# 服务端口
AUTH_PORT=8080
APISIX_PORT=9080
APISIX_ADMIN_PORT=9180
APISIX_METRICS_PORT=9091
APISIX_DASHBOARD_PORT=9000

# APISIX配置
APISIX_ADMIN_KEY=your-admin-key-change-this
