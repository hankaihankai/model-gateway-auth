# Spring 环境配置
SPRING_PROFILES_ACTIVE=prod

# MySQL 配置
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DATABASE=user_manager
MYSQL_USERNAME=new_api
MYSQL_PASSWORD=123456

# Redis 配置
REDIS_HOST=new-api-redis
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DATABASE=0

# 认证服务端口
AUTH_PORT=8188

# new-api 外部用户管理
NEW_API_USER_MANAGER_BASE_URL=http://new-api:3000
NEW_API_USER_MANAGER_AUTH_KEY=dkmicjearmmxiojrac39203458

# 网关密钥文件配置
GATEWAY_JWT_PRIVATE_KEY_FILE=/app/cert/gateway-jwt-private.pem
GATEWAY_JWT_PUBLIC_KEY_FILE=/app/cert/gateway-jwt-public.pem
GATEWAY_CREDENTIAL_KEY_ID=main
GATEWAY_CREDENTIAL_AES_KEY_FILE=/app/cert/gateway-credential-aes.key
APISIX_GATEWAY_SECRET_FILE=/app/cert/apisix-gateway-secret.txt
